
@inproceedings{ribeiro_anchors_2018,
	title = {Anchors: {High}-precision model-agnostic explanations},
	volume = {32},
	shorttitle = {Anchors},
	url = {https://ojs.aaai.org/index.php/aaai/article/view/11491},
	number = {1},
	urldate = {2026-02-05},
	booktitle = {Proceedings of the {AAAI} conference on artificial intelligence},
	author = {Ribeiro, Marco Tulio and Singh, Sameer and Guestrin, Carlos},
	year = {2018},
	note = {This article presents Anchor, a new explanation systme for complex neural networks. Compared to previous linearly weighted combinaison of the input features, Anchors can be interpreted as local sufficient condition for prediction.
Anchors are build on a set of predicates \$A\$ called a "rules". We can also see it as a function of instances \$x {\textbackslash}in X\$ :
\$\$A : 
	{\textbackslash}begin\{cases\}
		X {\textbackslash}longrightarrow {\textbackslash}\{0, 1{\textbackslash}\} {\textbackslash}{\textbackslash} 
		x {\textbackslash}longmapsto 
		{\textbackslash}begin\{cases\}
			1 {\textbackslash}text\{ if all rules are true for \} x {\textbackslash}{\textbackslash}
			0 {\textbackslash}text\{ otherwise\}
		{\textbackslash}end\{cases\}
	{\textbackslash}end\{cases\}
		\$\$
To link an set of rules \$A\$ on a prediction \$f(x)\$ (where \$f : X {\textbackslash}longrightarrow Y\$ is the black-box model, we can finally define Anchors of \$x\$ iff \$A(x) = 1\$ and \$A\$ is a sufficient condition for the prediction \$y = f(x)\$ :
\$\$	{\textbackslash}mathbb\{E\}\_\{{\textbackslash}mathcal\{D\}(z {\textbackslash}mid A)\}(1\_\{f(x)=f(z)\} {\textbackslash}geqslant {\textbackslash}tau\$\$
with \${\textbackslash}tau\$ the desired level of precision of the Anchor on \$x\$.
Computing Anchors is the difficult part of the process. This is a combinatorial optimization problem if we decide to choose anchors whihch satisfy a precision constraint with high probability.
\$\$	{\textbackslash}mathbb\{P\} (prec(A) {\textbackslash}geqslant {\textbackslash}tau) {\textbackslash}geqslant 1 - {\textbackslash}delta\$\$
with \$ prec(A) = {\textbackslash}mathbb\{E\}\_\{{\textbackslash}mathcal\{D\}(z {\textbackslash}mid A)\}(1\_\{f(x)=f(z)\}\$ called the anchors "precision". Among those anchors, we choose the largest coverage ones, where coverage is :
\$\$cov(A) = {\textbackslash}mathbb\{E\}\_\{{\textbackslash}mathcal\{D\}(z)\} (A(z))\$\$
Finally, the optimisation problem can be describe by :
\$\${\textbackslash}max\_\{{\textbackslash}mathbb\{P\} (prec(A) {\textbackslash}geqslant {\textbackslash}tau) {\textbackslash}geqslant 1 - {\textbackslash}delta\} cov(A)\$\$
Because the number of all possible anchor is exponential, we can perform an exhaustive search. That's why the article introduced the Bottom-Up approch:
1. **Initialization**: The anchor \$A\$ is initialized as an empty rule (applying to all instances).
2. **Candidate Generation**: In each iteration, a set of candidate rules \${\textbackslash}mathcal\{A\}\$ is generated by extending \$A\$ with one additional feature predicate \${\textbackslash}\{a\_i{\textbackslash}\}\$: \${\textbackslash}mathcal\{A\} = {\textbackslash}\{A {\textbackslash}wedge a\_i, A {\textbackslash}wedge a\_\{i+1\}, A {\textbackslash}wedge a\_\{i+2\}, ...{\textbackslash}\}\$
3. **Selection via Multi-Armed Bandit (MAB)**: To identify the best candidate without an exhaustive number of calls to \$f\$, the problem is formulated as a pure-exploration multi-armed bandit problem. The **KL-LUCB** algorithm is used to find the rule with the highest precision using a minimal set of samples.
4. **Termination**: The process terminates when a rule meets the statistical precision constraint: \${\textbackslash}mathbb\{P\} (prec(A) {\textbackslash}geqslant {\textbackslash}tau) {\textbackslash}geqslant 1 - {\textbackslash}delta\$
To address the limitations of a purely greedy search, the algorithm extends the construction to a **Beam Search** of size \$B\$.
- It maintains a set of \$B\$ current candidates instead of a single one.
- Among the multiple anchors identified that satisfy the precision threshold \${\textbackslash}tau\$, the algorithm outputs the one with the highest coverage \$cov(A)\$, effectively optimizing the original problem.
To provide a global understanding of the model, the article adapts a **Submodular Pick** (SP) procedure. The goal is to select a set of \$K\$ anchors that are non-redundant and cover as many instances in the validation set as possible.},
	keywords = {Axel},
	file = {Available Version (via Google Scholar):C\:\\Users\\Admin\\Zotero\\storage\\JHPWR8YT\\Ribeiro et al. - 2018 - Anchors High-precision model-agnostic explanations.pdf:application/pdf},
}

@inproceedings{marques-silva_efficient_2025,
	title = {Efficient and rigorous model-agnostic explanations},
	url = {https://ijcai-preprints.s3.us-west-1.amazonaws.com/2025/7066.pdf},
	urldate = {2026-02-05},
	booktitle = {Proceedings of the {Thirty}-{Fourth} {International} {Joint} {Conference} on {Artificial} {Intelligence}},
	author = {Marques-Silva, Joao and Lefebre-Lobaina, Jairo and Martinez, Vanina},
	year = {2025},
	note = {Explainable artificial intelligence (XAI) is at the core of trustworthy AI. Logic based XAI addresses the lack of rigor.  but in turn it exhibits some drawbacks, like scalability and the need to access the details of the machine learning model, which may reveal sensitive information. This paper builds on recent work on symbolic model-agnostic XAI, which is based on explaining samples of behavior of a blackbox ML model, and proposes efficient algorithms for the computation of explanations. With this, the paper aims to combine sub-symbolic XAI and logic XAI. First, the paper defines contrastive explanations (answers to “why not?”, sbCXps) and proves that computing the set of all contrastive explanations is in polynomial time. Second, they provide an improved algorithm in polynomial time to calculate one abductive explanation(answer to “why?”, sbAXps). In addition, the paper outlines practically efficient algorithms for the enumeration of abductive explanations, and for deciding feature relevance and necessity. 
A contrastive explanation is defined as a minimal set of features that are sufficient to change the model's prediction if their values are altered. The abductive explanation is found by finding the minimal set of features needed to keep the prediction unchanged. The link between constive and abductive explanations is that every abductive explanation must intersect with every contrastive explanation, and vice versa.},
	keywords = {Ant},
	pages = {2637--2646},
	file = {Available Version (via Google Scholar):C\:\\Users\\Admin\\Zotero\\storage\\WXCHSGM2\\Marques-Silva et al. - 2025 - Efficient and rigorous model-agnostic explanations.pdf:application/pdf},
}

@inproceedings{letoffe_towards_2025,
	title = {Towards trustable {SHAP} scores},
	volume = {39},
	url = {https://ojs.aaai.org/index.php/AAAI/article/view/34002},
	number = {17},
	urldate = {2026-02-05},
	booktitle = {Proceedings of the {AAAI} {Conference} on {Artificial} {Intelligence}},
	author = {Létoffé, Olivier and Huang, Xuanxiang and Marques-Silva, Joao},
	year = {2025},
	note = {This paper firstly explores the failings of original SHAP scores for classification and regression models, that is that the features having no influence on the decision may be assigned more importance in an explanation than features having the most influence. Then, they argue that these failings can be solely attributed to the characteristic function use in the computation of Shapley values. After introducing concepts and mathematical tools used in the computation of SHAP scores, they propose properties that characteristic functions should have to prevent such shortcomings. They should respect a strong value independence (i.e. mapping the classes to another space with a surjective function should not change the SHAP scores) and they should comply with features irrelevancy (i.e. a feature is irrelevant if and only if its SHAP score is null). The paper then suggest new characteristic functions respecting the desired properties, based on the abductive and contrastive explanations formalism (AXps and CXps). These properties are model-independant, giving trustable Shapley-based explanations for any classification or regression model. Finally, The paper talks about the complexity costs of computing SHAP scores based on such characteristic functions, affirming that it becomes an NP-hard problem for most models, while there exists polynomial-time algorithms for ML models represented by tabular representations.
This paper was very formal. Indeed, it introduced a lot of propositions and theorems, and we must appreciate that all the proofs are provided at the end. But I think it misses some practical demonstrations to illustrate the enhanced explanations, we are left with theoretical results but no algorithm to implement them and no visualization of what’s put forward.},
	keywords = {Noé},
	pages = {18198--18208},
	file = {Available Version (via Google Scholar):C\:\\Users\\Admin\\Zotero\\storage\\VU8WI5JJ\\Létoffé et al. - 2025 - Towards trustable SHAP scores.pdf:application/pdf},
}

@inproceedings{lundberg_unified_2017,
	title = {A {Unified} {Approach} to {Interpreting} {Model} {Predictions}},
	volume = {30},
	url = {https://proceedings.neurips.cc/paper_files/paper/2017/hash/8a20a8621978632d76c43dfd28b67767-Abstract.html},
	urldate = {2026-02-09},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Lundberg, Scott M and Lee, Su-In},
	year = {2017},
	note = {This paper proposes a general framework to interpret predictions made by machine learning models, especially complex black-box models. The authors highlight that many explanation methods already exist (such as LIME, DeepLIFT, and feature importance techniques), but they rely on different principles and are often difficult to compare.
To address this issue, the authors introduce a unified framework based on additive feature attribution models, where a prediction is explained as the sum of contributions from each feature. In this setting, each feature is assigned a weight that represents its impact on the prediction.
The paper shows that several existing methods can be interpreted as special cases of this framework. For instance, LIME builds a local approximation of the model, while DeepLIFT assigns contributions by comparing predictions to a reference value. However, these methods do not always satisfy important properties such as consistency.
In this context, the authors introduce SHAP, a method based on Shapley values from game theory, which guarantees key properties such as consistency, symmetry, and model fidelity. SHAP therefore provides a theoretically grounded way to assign feature importance.
The main contribution of the paper is twofold: first, it provides a unified framework that helps understand and compare different explanation methods, and second, it demonstrates that Shapley values offer an optimal solution within this framework. This article is a key reference in Explainable AI, as it structures the field and clarifies the relationships between different interpretability approaches.},
	keywords = {Matthias},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\3XC9NK3E\\Lundberg et Lee - 2017 - A Unified Approach to Interpreting Model Predictions.pdf:application/pdf},
}

@inproceedings{ignatiev_abduction-based_2019,
	title = {Abduction-based explanations for machine learning models},
	volume = {33},
	url = {https://aaai.org/ojs/index.php/AAAI/article/view/3964},
	number = {01},
	urldate = {2026-02-09},
	booktitle = {Proceedings of the {AAAI} conference on artificial intelligence},
	author = {Ignatiev, Alexey and Narodytska, Nina and Marques-Silva, Joao},
	year = {2019},
	note = {This paper proposes an approach to explaining machine learning model predictions based on abductive reasoning, a form of logical inference that aims to identify the most plausible causes of an observed outcome.
The authors point out that many existing explanation methods (such as LIME or SHAP) rely on approximations or feature importance scores, which may limit the precision and reliability of explanations. To address this, they introduce an alternative approach grounded in formal logic, which enables the generation of exact and minimal explanations.
In practice, the idea is to represent the machine learning model in a logical form (e.g., as constraints or logical formulas), and then compute a minimal subset of features or conditions that is sufficient to explain a given prediction. These are called abductive explanations, as they identify the key elements responsible for the model’s decision.
The approach distinguishes between two main types of explanations:
minimal sufficient explanations (which features are enough to justify the prediction)
necessary explanations (which features are required to maintain the prediction)
The main contribution of the paper is to provide a logic-based explanation framework that ensures strong properties such as model fidelity and minimality of explanations. Compared to approximate methods, this approach offers more rigorous explanations, although it may involve higher computational costs.
This article is important in Explainable AI as it highlights a symbolic and logic-based alternative to statistical approaches like SHAP or LIME, and helps broaden the understanding of interpretability methods.},
	keywords = {Matthias},
	pages = {1511--1519},
	file = {Available Version (via Google Scholar):C\:\\Users\\Admin\\Zotero\\storage\\CUZN9QPY\\Ignatiev et al. - 2019 - Abduction-based explanations for machine learning models.pdf:application/pdf},
}

@inproceedings{ignatiev_towards_2020,
	title = {Towards trustable explainable {AI}},
	url = {https://research.monash.edu/en/publications/towards-trustable-explainable-ai},
	urldate = {2026-02-09},
	booktitle = {International {Joint} {Conference} on {Artificial} {Intelligence}-{Pacific} {Rim} {International} {Conference} on {Artificial} {Intelligence} 2020},
	publisher = {Association for the Advancement of Artificial Intelligence (AAAI)},
	author = {Ignatiev, Alexey},
	year = {2020},
	note = {ML will prevail as a generic computing paradigm and will find an ever growing range of practical applications, many of which will have to do with various aspects of our lives. Unfortunately, ML models, on occasion, catastrophically fail.They can also support poor decisions due to bias in the model. As a result, there is a critical need to understand the behavior of ML models, analyze the failures of the models, debug them, and possibly repair them. But most existing approaches to explain ML models are of heuristical nature and are logically unsound, which creates a lack of trust in ML models. The recent approach (2018) uses provably correct explanations at the cost of lower scalability which is fundamentally different from heuristical methods. This approach use logic` `and logical representation which is called abductive reasoning and can be used to explain a model but also to validate heuristic explanation. Because this explainability method is based on logic, the explanation can be proved and simplified. This article illustrates that Anchor can break on easy example (Zoo dataset), and also provide an assessment of LIME, Anchor and SHAP, where they often have more incorrect explanations than correct ones.},
	keywords = {Ant},
	pages = {5154--5158},
}

@misc{izza_explaining_2021,
	title = {On {Explaining} {Random} {Forests} with {SAT}},
	url = {http://arxiv.org/abs/2105.10278},
	doi = {10.48550/arXiv.2105.10278},
	abstract = {Random Forest (RFs) are among the most widely used Machine Learning (ML) classifiers. Even though RFs are not interpretable, there are no dedicated non-heuristic approaches for computing explanations of RFs. Moreover, there is recent work on polynomial algorithms for explaining ML models, including naive Bayes classifiers. Hence, one question is whether finding explanations of RFs can be solved in polynomial time. This paper answers this question negatively, by proving that computing one PI-explanation of an RF is D{\textasciicircum}P-complete. Furthermore, the paper proposes a propositional encoding for computing explanations of RFs, thus enabling finding PI-explanations with a SAT solver. This contrasts with earlier work on explaining boosted trees (BTs) and neural networks (NNs), which requires encodings based on SMT/MILP. Experimental results, obtained on a wide range of publicly available datasets, demontrate that the proposed SAT-based approach scales to RFs of sizes common in practical applications. Perhaps more importantly, the experimental results demonstrate that, for the vast majority of examples considered, the SAT-based approach proposed in this paper significantly outperforms existing heuristic approaches.},
	urldate = {2026-02-09},
	publisher = {arXiv},
	author = {Izza, Yacine and Marques-Silva, Joao},
	month = may,
	year = {2021},
	note = {Random Forests are among the most widely used Machine Learning classifiers. Even though RFs are not interpretable, there are no dedicated non-heuristic approaches for computing explanations of RFs. Moreover, there is recent work on polynomial algorithms for explaining ML models, including naive Bayes classifiers. Hence, one question is whether finding explanations of RFs can be solved in polynomial time. This paper answers this question negatively. This paper extends earlier work on model-precise non-heuristic explainability. This paper proposes a novel approach, purely propositional encoding for computing PI (or abductive) explanations of Random Forest classifiers. Experimental results demonstrate that the proposed SAT-based approach scales to realistically sized random forests, For most of the examples considered, the SAT-based approach significantly outperforms existing model-agnostic heuristic approaches, such as Anchor and is also much faster than anchor, the average running time of RFxpl is less than 1sec. RFxpl works by encoding the RF into a propositional encoding, Split the encoded RF into hard clauses (H) and soft clauses (S). H is the encoded model but is forced to give another prediction than the original one. S is specific features of the models that can be dropped. Then H and S are used in a SAT solver to find a Minimal Unsatisfiable Subset (MUS).},
	keywords = {Ant},
	file = {Preprint PDF:C\:\\Users\\Admin\\Zotero\\storage\\ZTBUNTNY\\Izza et Marques-Silva - 2021 - On Explaining Random Forests with SAT.pdf:application/pdf},
}

@misc{shih_symbolic_2018,
	title = {A {Symbolic} {Approach} to {Explaining} {Bayesian} {Network} {Classifiers}},
	url = {http://arxiv.org/abs/1805.03364},
	doi = {10.48550/arXiv.1805.03364},
	abstract = {We propose an approach for explaining Bayesian network classifiers, which is based on compiling such classifiers into decision functions that have a tractable and symbolic form. We introduce two types of explanations for why a classifier may have classified an instance positively or negatively and suggest algorithms for computing these explanations. The first type of explanation identifies a minimal set of the currently active features that is responsible for the current classification, while the second type of explanation identifies a minimal set of features whose current state (active or not) is sufficient for the classification. We consider in particular the compilation of Naive and Latent-Tree Bayesian network classifiers into Ordered Decision Diagrams (ODDs), providing a context for evaluating our proposal using case studies and experiments based on classifiers from the literature.},
	urldate = {2026-02-09},
	publisher = {arXiv},
	author = {Shih, Andy and Choi, Arthur and Darwiche, Adnan},
	month = may,
	year = {2018},
	note = {This article focuses on the problem of explaining decisions made by Bayesian network classifiers, which are often difficult to interpret because they rely on probabilistic reasoning.
The authors propose a symbolic approach that transforms the model into a more understandable form using logical expressions. The goal is to make it easier to understand why a specific prediction is made for a given input.
More precisely, the method provides local explanations, meaning explanations for one specific decision. It identifies which variables have the most influence and under which conditions the prediction is obtained. Unlike methods such as LIME or SHAP, which give approximate explanations, this approach gives exact explanations that are fully consistent with the model.
Overall, the paper shows that this method helps to make Bayesian classifiers more transparent and easier to interpret, while keeping a high level of accuracy},
	keywords = {Matthias},
	file = {Preprint PDF:C\:\\Users\\Admin\\Zotero\\storage\\Y5A798ZJ\\Shih et al. - 2018 - A Symbolic Approach to Explaining Bayesian Network Classifiers.pdf:application/pdf},
}

@article{fryer_shapley_2021,
	title = {Shapley {Values} for {Feature} {Selection}: {The} {Good}, the {Bad}, and the {Axioms}},
	volume = {9},
	issn = {2169-3536},
	shorttitle = {Shapley {Values} for {Feature} {Selection}},
	url = {https://ieeexplore.ieee.org/abstract/document/9565902},
	doi = {10.1109/ACCESS.2021.3119110},
	abstract = {The Shapley value has become popular in the Explainable AI (XAI) literature, thanks, to a large extent, to a solid theoretical foundation, including four “favourable and fair” axioms for attribution in transferable utility games. The Shapley value is probably the only solution concept satisfying these axioms. In this paper, we introduce the Shapley value and draw attention to its recent uses as a feature selection tool. We call into question this use of the Shapley value, using simple, abstract “toy” counterexamples to illustrate that the axioms may work against the goals of feature selection. From this, we develop a number of insights that are then investigated in concrete simulation settings, with a variety of Shapley value formulations, including SHapley Additive exPlanations (SHAP) and Shapley Additive Global importancE (SAGE). The aim is not to encourage any use of the Shapley value for feature selection, but we aim to clarify various limitations around their current use in the literature. In so doing, we hope to help demystify certain aspects of the Shapley value axioms that are viewed as “favourable”. In particular, we wish to highlight that the favourability of the axioms depends non-trivially on the way in which the Shapley value is appropriated in the XAI application.},
	urldate = {2026-02-16},
	journal = {IEEE Access},
	author = {Fryer, Daniel and Strümke, Inga and Nguyen, Hien},
	year = {2021},
	note = {This paper summarizes the SHAP and SAGE feature explanation methods based on the Shapley values, while drawing attention on the fact that Shapley values are not inherently suited for feature selection and may in some cases fail in this domain. The relevance of such Shapley values for feature selection to a ML task lies in the game formulation and more precisely in the evaluation function. Then, the paper introduce the Shapley value formula, and the five interesting axioms that results : Efficiency, Null Player, Symmetry, Additivity, and Balanced Contributions. It also expresses the meanings of these axioms, highlighting the possible shortcomings for ML tasks when used with the wrong formulation. Notably, the authors argue that averaging across all submodels during the computation of the evaluation function can suffer from the presence of dominant feature, that theses axioms give poor performance of a feature on particularly small models, and that a feature acting as a secret holder will be ignore and assigned lower importance. To prove these, they experiment on very simple toy models on which they know the decision process, and that each highlight an issue when applying SHAP and SAGE methods.
Even though this paper clearly put forward the failings of Shapley values for feature selection based on its axioms, it doesn’t suggest solutions to overcome these shortcomings, which makes it less interesting for our researches. Other papers have already shed light on Shapley values failings while proposing new methods more adapted to the problem of explanation of the feature importance. However, the authors conducted a very formal identification of the problems that are not only based on empirical studies, but more on the formal definition of the Shapley value itself, which is something we can surely acclaim.},
	keywords = {Noé},
	pages = {144352--144360},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\BDA9XXT3\\Fryer et al. - 2021 - Shapley Values for Feature Selection The Good, the Bad, and the Axioms.pdf:application/pdf},
}

@inproceedings{merrick_explanation_2020,
	address = {Cham},
	title = {The {Explanation} {Game}: {Explaining} {Machine} {Learning} {Models} {Using} {Shapley} {Values}},
	isbn = {978-3-030-57321-8},
	shorttitle = {The {Explanation} {Game}},
	doi = {10.1007/978-3-030-57321-8_2},
	abstract = {A number of techniques have been proposed to explain a machine learning model’s prediction by attributing it to the corresponding input features. Popular among these are techniques that apply the Shapley value method from cooperative game theory. While existing papers focus on the axiomatic motivation of Shapley values, and efficient techniques for computing them, they offer little justification for the game formulations used, and do not address the uncertainty implicit in their methods’ outputs. For instance, the popular SHAP algorithm’s formulation may give substantial attributions to features that play no role in the model. In this work, we illustrate how subtle differences in the underlying game formulations of existing methods can cause large differences in the attributions for a prediction. We then present a general game formulation that unifies existing methods, and enables straightforward confidence intervals on their attributions. Furthermore, it allows us to interpret the attributions as contrastive explanations of an input relative to a distribution of reference inputs. We tie this idea to classic research in cognitive psychology on contrastive explanations, and propose a conceptual framework for generating and interpreting explanations for ML models, called formulate, approximate, explain (FAE). We apply this framework to explain black-box models trained on two UCI datasets and a Lending Club dataset.},
	language = {en},
	booktitle = {Machine {Learning} and {Knowledge} {Extraction}},
	publisher = {Springer International Publishing},
	author = {Merrick, Luke and Taly, Ankur},
	editor = {Holzinger, Andreas and Kieseberg, Peter and Tjoa, A Min and Weippl, Edgar},
	year = {2020},
	note = {This paper firstly introduce Shapley values formalism for computing explanations of single instances of models. Shapley values are computed by measuring the difference between the instance predictions in contrast of reference instances that are chosen to follow a specific distribution. The authors sustain that the choice of this reference distribution is very important and that the differences in feature attributions between every existing SHAP-based methods lies in this specific choice. It then explores the different already existing SHAP-based methods (TreeSHAP, KernelSHAP, QII), highlighting for each their related reference distribution. For instance, one can choose to sample reference instances from the distribution of the dataset, from the joint marginal distribution of all the features, or even from a uniform distribution over all the features space. The paper shows shortcomings in these existing methods, and propose a unified formulation for the Shapley value in order to build confidence intervals on the computed attributions to measure the uncertainty, regardless of the chosen reference distribution. Then, the paper proposes a framework when having recourse to SHAP scores, called Formulate - Approximate - Explain (FAE). One should firstly formulate a contrastive question related to the classification task to pin down the desired distribution of the references. Then, we approximate this distribution of the attribution vectors by sampling the chosen distribution. And finally, we summarize the obtained Shapley value, also presenting the confidence intervals.
The paper apply this novel framework on several real-life examples (UCI Bike Sharing, Adult Income and Lending Club datasets using LightGBM and GBDT models). The results show the importance of the generated confidence intervals over the computed attributions, as well as the importance of the choice of the reference distribution in the contrastive process. It also proposes the use of clustering to identify sets of instances that may be interesting to contrast the explained instance with, and also sets that are not relevant for the explanation.
Overall, this is a very clear paper that presents a well defined and very relevant method framework for improving the effectiveness of SHAP-based explanations. Every property put forward is demonstrated and the results are complete and relevant in regard of the problem.},
	keywords = {Noé},
	pages = {17--38},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\ZXIXWLS5\\Merrick et Taly - 2020 - The Explanation Game Explaining Machine Learning Models Using Shapley Values.pdf:application/pdf},
}

@inproceedings{airani_stability_2025,
	title = {Stability and {Consistency} {Analysis} of {SHAP} and {LIME} {Explanations} {Across} {Machine} {Learning} {Models}},
	url = {https://ieeexplore.ieee.org/abstract/document/11378102},
	doi = {10.1109/ICERECT65215.2025.11378102},
	abstract = {In the era of interpretable machine learning, explaining model predictions is essential for transparency, trust, and accountability, particularly in critical domains. This project presents a comprehensive comparative study of two widely adopted model-agnostic explanation techniques: SHAP (SHapley Additive exPlanations) and LIME (Local Interpretable Model-agnostic Explanations). We evaluate their stability and consistency across various machine learning models, including Random Forests, Support Vector Machines, and Neural Networks, using stability metrics such as Jaccard similarity and Spearman rank correlation to assess the robustness of the top-k important features identified by each explainer under repeated sampling. Our findings reveal significant differences in the behavior of SHAP and LIME across models, indicating that SHAP generally provides more consistent and stable explanations. This study not only offers insights into the reliability of feature attributions but also aids practitioners in selecting appropriate interpretability tools based on their specific use case and model type.},
	urldate = {2026-02-19},
	booktitle = {2025 5th {International} {Conference} on {Emerging} {Research} in {Electronics}, {Computer} {Science} and {Technology} ({ICERECT})},
	author = {Airani, Samarth Satish and Sinha, Sumana and Bhat, Shreya R and K, Deepthi},
	month = sep,
	year = {2025},
	note = {This paper compare SHAP and LIME across various machine learning models using stability metrics such as Jaccard similarity and Spearman rank correlation to assess the robustness of the top-k important features identified by each explainer under repeated sampling. This revealed a significant difference in behavior of SHAP and LIME across models, indicating that SHAP often generally provides more consistent and stable explanations. This study not only offers insights into the reliability of feature attributions but also aids practitioners in selecting appropriate interpreters. Jaccard similarity measures the overlap of top important features and Spearman rank correlation evaluates agreement in feature rankings. This paper also gives us a visualization of correlation and stability patterns among explanations to aid interpretation and practical decision making. This study used two datasets : Iris and Diabetes. Their results was that despite LIME’s superior stability in this study, it is known to suffer from instability in other contexts due to its sampling process and reliance on locally linear approximations, which can lead to variability in explanations depending on parameter settings. For SHAP, although theoretically grounded, is computationally expensive and may yield less stable explanations on high-dimensional or noisy data. So even if LIME is technically more stable, in practice it is less stable than SHAP.},
	keywords = {Ant},
	pages = {1--6},
}

@article{rudin_stop_2019,
	title = {Stop explaining black box machine learning models for high stakes decisions and use interpretable models instead},
	volume = {1},
	copyright = {2019 Springer Nature Limited},
	issn = {2522-5839},
	url = {https://www.nature.com/articles/s42256-019-0048-x},
	doi = {10.1038/s42256-019-0048-x},
	abstract = {Black box machine learning models are currently being used for high-stakes decision making throughout society, causing problems in healthcare, criminal justice and other domains. Some people hope that creating methods for explaining these black box models will alleviate some of the problems, but trying to explain black box models, rather than creating models that are interpretable in the first place, is likely to perpetuate bad practice and can potentially cause great harm to society. The way forward is to design models that are inherently interpretable. This Perspective clarifies the chasm between explaining black boxes and using inherently interpretable models, outlines several key reasons why explainable black boxes should be avoided in high-stakes decisions, identifies challenges to interpretable machine learning, and provides several example applications where interpretable models could potentially replace black box models in criminal justice, healthcare and computer vision.},
	language = {en},
	number = {5},
	urldate = {2026-02-19},
	journal = {Nature Machine Intelligence},
	author = {Rudin, Cynthia},
	month = may,
	year = {2019},
	note = {This Duke University, Cynthia Rudin, is convinced that black-box models are not the solution for high-stakes decision and constitute a real danger.
In this article, she present many arguments in order to demonstrate that explainable black bowed models should be avoided. “Black-boxes” models are therefore defined as:
- a too complicated function to human comprehension
    
- or a proprietary function.
    
Her first argument is that there’s not always a trade-off between model accuracy and interpretability. According to her, it is the main reason why researcher don’t work on explainable models. Moreover, there is often not accuracy differences between complex classifiers and more simple ones when using preprocessing.
Because of the complexity of the explanation problem, sometimes, it don’t provide a enough detail to. understand the model behavior. To illustrate this phenomena, she use n image-classifier model on a Siberian husky.},
	keywords = {Axel},
	pages = {206--215},
}

@inproceedings{amgoud_leveraging_2023,
	title = {Leveraging {Argumentation} for {Generating} {Robust} {Sample}-based {Explanations}},
	doi = {10.24963/ijcai.2023/346},
	abstract = {Explaining predictions made by inductive classifiers has become crucial with the rise of complex models acting more and more as black-boxes. Abductive explanations are one of the most popular types of explanations that are provided for the purpose. They highlight feature-values that are sufficient for making predictions. In the literature, they are generated by exploring the whole feature space, which is unreasonable in practice. This paper solves the problem by introducing explanation functions that generate abductive explanations from a sample of instances. It shows that such functions should be defined with great care since they cannot satisfy two desirable properties at the same time, namely existence of explanations for every individual decision (success) and correctness of explanations (coherence). The paper provides a parameterized family of argumentation-based explanation functions, each of which satisfies one of the two properties. It studies their formal properties and their experimental behaviour on different datasets.},
	author = {Amgoud, Leila and Muller, Philippe and Trenquier, Henri},
	month = aug,
	year = {2023},
	note = {Abductive explanations are one of the most popular types of explanations that are provided for the purpose. They highlight feature-values that are sufficient for making predictions. In the literature, they are generated by exploring the whole feature space, which is unreasonable in practice. This paper solves the problem by introducing explanation functions that generate abductive explanations from a sample of instances. It shows that such functions should be defined with great care since they cannot satisfy two desirable properties at the same time, namely existence of explanations for every individual decision (success) and correctness of explanations (coherence). This paper investigates explanation functions that generate abductive explanations from a subset of feature space while satisfying desirable properties. Its contributions are fourfold: proving an impossibility result, which states that a function that generates abductive explanations from a subset of instances cannot guarantee both existence of success and coherence, the second contribution consists of a parameterized family of argumentation-based explanation functions, each of which satisfies one of the two incompatible properties, the third contribution is a formal analysis and a comprehensive comparison of the new functions (from the second contribution, The fourth contribution is an experimental analysis of the functions on various datasets. The results confirm that abductive explanations that are generated from datasets (as done by Anchors) are generally incorrect.The new functions which guarantee correctness perform well as they explain quite an important proportion of instances. These functions start by generating arguments in favour of classes, then identify attacks among them and use stable semantics for generating sets of arguments that can be jointly accepted.},
	keywords = {Ant},
	pages = {3104--3111},
}

@misc{cooper_abductive_2024,
	title = {Abductive explanations of classifiers under constraints: {Complexity} and properties},
	shorttitle = {Abductive explanations of classifiers under constraints},
	url = {http://arxiv.org/abs/2409.12154},
	doi = {10.48550/arXiv.2409.12154},
	abstract = {Abductive explanations (AXp's) are widely used for understanding decisions of classifiers. Existing definitions are suitable when features are independent. However, we show that ignoring constraints when they exist between features may lead to an explosion in the number of redundant or superfluous AXp's. We propose three new types of explanations that take into account constraints and that can be generated from the whole feature space or from a sample (such as a dataset). They are based on a key notion of coverage of an explanation, the set of instances it explains. We show that coverage is powerful enough to discard redundant and superfluous AXp's. For each type, we analyse the complexity of finding an explanation and investigate its formal properties. The final result is a catalogue of different forms of AXp's with different complexities and different formal guarantees.},
	urldate = {2026-02-17},
	publisher = {arXiv},
	author = {Cooper, Martin and Amgoud, Leila},
	month = sep,
	year = {2024},
	note = {This paper focuses on abductive explanations (AXp), which aim to identify a minimal set of features that is sufficient to explain a classifier’s decision. The authors highlight that standard definitions of AXp usually assume that features are independent, which is rarely the case in real-world applications. In practice, there are often constraints between features, and ignoring them can lead to a large number of redundant, irrelevant, or misleading explanations.
The paper distinguishes between two main types of constraints: integrity constraints (IC), which rule out impossible combinations of feature values (e.g., “a man cannot be pregnant”), and dependency constraints (DC), which express relationships between features (e.g., “if a person is pregnant, then they must be female”). While previous work may consider integrity constraints, dependency constraints are often ignored, which can result in an exponential number of explanations, many of which are redundant or unnecessary.
To address this issue, the authors introduce a new approach based on the concept of coverage, defined as the set of instances that an explanation applies to. This notion allows explanations to be compared and filtered by keeping only the most relevant ones. Based on this idea, they propose three new types of explanations:
CPI-Xp (coverage-based explanations), which prioritize explanations covering more instances
mCPI-Xp (minimal explanations), which are also subset-minimal
pCPI-Xp (preferred explanations), which remove equivalent explanations
These new definitions help solve several key problems: they eliminate redundant explanations, significantly reduce their number (sometimes exponentially), and properly take into account dependencies between features.
A major part of the paper is devoted to analyzing the computational complexity of these explanations. The authors show that checking or computing these new types of explanations is more computationally demanding than standard approaches (e.g., problems can be Π₂{\textasciicircum}P-complete), which raises challenges for practical use.
To overcome this limitation, the authors propose a sample-based approach, where explanations are computed using a dataset instead of the entire feature space. This reduces the computational complexity to polynomial time, making the method more practical. However, this introduces a trade-off: explanations become easier to compute but are less reliable globally, since they are only valid for the observed data.
Finally, the paper defines several desirable theoretical properties that explanation methods should satisfy, such as coherence, minimality, and independence. The authors show that their preferred explanations (pCPI-Xp) are the only ones that satisfy all these properties, making them theoretically robust.
Overall, the main contribution of this paper is to provide a comprehensive framework for generating abductive explanations that are more relevant, less redundant, and adapted to real-world constraints, while also highlighting an important trade-off between explanation quality and computational cost. This work is particularly important in Explainable AI, as it shows that incorporating constraints is essential for producing meaningful and reliable explanations.},
	keywords = {Matthias},
	file = {Preprint PDF:C\:\\Users\\Admin\\Zotero\\storage\\PRKX2Z3V\\Cooper and Amgoud - 2024 - Abductive explanations of classifiers under constr.pdf:application/pdf;Snapshot:C\:\\Users\\Admin\\Zotero\\storage\\QDUEFEI9\\Cooper and Amgoud - 2024 - Abductive explanations of classifiers under constr.html:text/html},
}

@article{thanathamathee_shap-instance_2024,
	title = {{SHAP}-{Instance} {Weighted} and {Anchor} {Explainable} {AI}: {Enhancing} {XGBoost} for {Financial} {Fraud} {Detection}},
	volume = {8},
	shorttitle = {{SHAP}-{Instance} {Weighted} and {Anchor} {Explainable} {AI}},
	doi = {10.28991/ESJ-2024-08-06-016},
	abstract = {This research aims to enhance financial fraud detection by integrating SHAP-Instance Weighting and Anchor Explainable AI with XGBoost, addressing challenges of class imbalance and model interpretability. The study extends SHAP values beyond feature importance to instance weighting, assigning higher weights to more influential instances. This focuses model learning on critical samples. It combines this with Anchor Explainable AI to generate interpretable if-then rules explaining model decisions. The approach is applied to a dataset of financial statements from the listed companies on the Stock Exchange of Thailand. The method significantly improves fraud detection performance, achieving perfect recall for fraudulent instances and substantial gains in accuracy while maintaining high precision. It effectively differentiates between non-fraudulent, fraudulent, and grey area cases. The generated rules provide transparent insights into model decisions, offering nuanced guidance for risk management and compliance. This research introduces instance weighting based on SHAP values as a novel concept in financial fraud detection. By simultaneously addressing class imbalance and interpretability, the integrated approach outperforms traditional methods and sets a new standard in the field. It provides a robust, explainable solution that reduces false positives and increases trust in fraud detection models. Doi: 10.28991/ESJ-2024-08-06-016 Full Text: PDF},
	journal = {Emerging Science Journal},
	author = {Thanathamathee, Putthiporn and Sawangarreerak, Siriporn and Chantamunee, Siripinyo and Mohd Nizam, Dinna},
	month = dec,
	year = {2024},
	note = {This paper presents a real-case application of SHAP-values and Anchors in fraud detection systems. While traditional statistical methods are common, they struggle with the complex nature of modern fraud. The authors enhance the XGBoost model by using a novel SHAP-instance weighting method to prioritize learning from the most informative samples. To solve the massive class imbalance in the Thailand Stock Exchange dataset, they combine RENN and SMOTE techniques before optimizing the model with Optuna and Hyperband.  
The resulting model effectively differentiates between non-fraudulent, fraudulent, and "grey area" behaviors. By reaching a perfect recall (1.000) for fraudulent cases, this approach sets a new standard for accuracy and trust. Furthermore, Anchors are used to translate "black-box" predictions into easy-to-understand if-then rules, providing clear insights for risk management. However, integrating these SHAP and Anchor systems increases the computational load and total processing time.},
	keywords = {Axel, Noé},
	pages = {2404--2430},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\WDSZASX9\\Thanathamathee et al. - 2024 - SHAP-Instance Weighted and Anchor Explainable AI.pdf:application/pdf},
}

@misc{yu_manchors_2026,
	title = {{MAnchors}: {Memorization}-{Based} {Acceleration} of {Anchors} via {Rule} {Reuse} and {Transformation}},
	shorttitle = {{MAnchors}},
	url = {http://arxiv.org/abs/2502.11068},
	doi = {10.48550/arXiv.2502.11068},
	abstract = {Anchors is a popular local model-agnostic explanation technique whose applicability is limited by its computational inefficiency. To address this limitation, we propose a memorization-based framework that accelerates Anchors while preserving explanation fidelity and interpretability. Our approach leverages the iterative nature of Anchors' algorithm which gradually refines an explanation until it is precise enough for a given input by storing and reusing intermediate results obtained during prior explanations. Specifically, we maintain a memory of low-precision, high-coverage rules and introduce a rule transformation framework to adapt them to new inputs: the horizontal transformation adapts a pre-trained explanation to the current input by replacing features, and the vertical transformation refines the general explanation until it is precise enough for the input. We evaluate our method across tabular, text, and image datasets, demonstrating that it significantly reduces explanation generation time while maintaining fidelity and interpretability, thereby enabling the practical adoption of Anchors in time-sensitive applications.},
	urldate = {2026-02-17},
	publisher = {arXiv},
	author = {Yu, Haonan and Liu, Junhao and Zhang, Xin},
	month = jan,
	year = {2026},
	note = {\#\#\# MAnchors: Memorization-Based Acceleration
This paper presents a framework that accelerates the computation of Anchors through a **memorization approach**.
**The Problem:** Anchors is a model-agnostic local explanation system based on if-then rules. For every prediction, a set of rules must be calculated for the given input to explain the model's behavior. Currently, these rules are re-calculated from scratch for every new instance, even if the inputs are nearly identical, leading to high computational costs.
**The MAnchors Solution:** This framework stores previously calculated rules to adapt them to new, similar inputs. However, because the input space is vast, exact matches are rare, and storing every final anchor would create a significant storage issue.
To solve this, MAnchors leverages the iterative construction of Anchors to store only **minimal low-precision, high-coverage rules**. These rules are more general, allowing them to match a larger set of potential inputs.
**The MAnchors Algorithm handles two scenarios:**
1. **Memory Miss**: If the stored rules are not similar enough to the current input, the system defaults to the standard Anchors computation.
    
2. **Memory Hit**: If a sufficiently similar rule exists in memory, it is refined using two types of transformations:
    
    - **Horizontal Transformation**: Adapts the rule to the new input's feature space by substituting predicates with the most similar available features.
        
    - **Vertical Transformation**: Refines the stored rule by adding predicates until it meets the desired precision.
        
**Experimental Results:** Researchers tested the framework on tabular, text, and image datasets to evaluate performance. These experiments confirmed that MAnchors introduces negligible time overhead compared to the original system. Furthermore, thanks to the vertical transformation, this approach maintains the explanation quality of the original Anchors while significantly reducing computation time (up to 8.74x for Llama 2).},
	keywords = {Axel},
	file = {Preprint PDF:C\:\\Users\\Admin\\Zotero\\storage\\ITQI85WU\\Yu et al. - 2026 - MAnchors Memorization-Based Acceleration of Ancho.pdf:application/pdf},
}

@misc{ribeiro_nothing_2016,
	title = {Nothing {Else} {Matters}: {Model}-{Agnostic} {Explanations} {By} {Identifying} {Prediction} {Invariance}},
	shorttitle = {Nothing {Else} {Matters}},
	url = {http://arxiv.org/abs/1611.05817},
	doi = {10.48550/arXiv.1611.05817},
	abstract = {At the core of interpretable machine learning is the question of whether humans are able to make accurate predictions about a model's behavior. Assumed in this question are three properties of the interpretable output: coverage, precision, and effort. Coverage refers to how often humans think they can predict the model's behavior, precision to how accurate humans are in those predictions, and effort is either the up-front effort required in interpreting the model, or the effort required to make predictions about a model's behavior. In this work, we propose anchor-LIME (aLIME), a model-agnostic technique that produces high-precision rule-based explanations for which the coverage boundaries are very clear. We compare aLIME to linear LIME with simulated experiments, and demonstrate the flexibility of aLIME with qualitative examples from a variety of domains and tasks.},
	urldate = {2026-02-21},
	publisher = {arXiv},
	author = {Ribeiro, Marco Tulio and Singh, Sameer and Guestrin, Carlos},
	month = nov,
	year = {2016},
	note = {This article presents the evolution of LIME system by adding Anchors to clearly define LIME coverage boundaries. Indeed, by construction LIME perturbs the output representation \$x'\$ of a black-box model \$f\$ by selecting random \$x'\$ components according to a distribution \${\textbackslash}pi\_x\$. However, this \$ {\textbackslash}pi\_x\$ doesn't define a clear zone around \$x'\$ where the system select the perturbed inputs to give to the models, ones can be very close and the other very far. So that human cannot really understand which feature is more important than another.
That's why, aLIME is an IF-THEN rules-based system that "anchors" a prediction features such that changing the others don't change de black-box model output. By this approach, precision (defined as how accurate humans are in those predictions) is needed but a too large set of rules only specific to a single instance is not useful for model understandability. Then the combinatorial aLIME problem if to find the shortest Anchor with high precision.},
	keywords = {Axel},
	file = {Preprint PDF:C\:\\Users\\Admin\\Zotero\\storage\\LU73ETDK\\Ribeiro et al. - 2016 - Nothing Else Matters Model-Agnostic Explanations By Identifying Prediction Invariance.pdf:application/pdf},
}

@article{arenas_tractability_2021,
	title = {The {Tractability} of {SHAP}-{Score}-{Based} {Explanations} for {Classification} over {Deterministic} and {Decomposable} {Boolean} {Circuits}},
	volume = {35},
	copyright = {Copyright (c) 2021 Association for the Advancement of Artificial Intelligence},
	issn = {2374-3468},
	url = {https://ojs.aaai.org/index.php/AAAI/article/view/16825},
	doi = {10.1609/aaai.v35i8.16825},
	abstract = {Scores based on Shapley values are widely used for providing explanations to classification results over machine learning models. A prime example of this is the influential SHAP-score, a version of the Shapley value that can help explain the result of a learned model on a specific entity by assigning a score to every feature. While in general computing Shapley values is a computationally intractable problem, it has recently been claimed that the SHAP-score can be computed in polynomial time over the class of decision trees. In this paper, we provide a proof of a stronger result over Boolean models: the SHAP-score can be computed in polynomial time over deterministic and decomposable Boolean circuits. Such circuits, also known as tractable Boolean circuits, generalize a wide range of Boolean circuits and binary decision diagrams classes, including binary decision trees, Ordered Binary Decision Diagrams (OBDDs) and Free Binary Decision Diagrams (FBDDs). We also establish the computational limits of the notion of SHAP-score by observing that, under a mild condition, computing it over a class of Boolean models is always polynomially as hard as the model counting problem for that class. This implies that both determinism and decomposability are essential properties for the circuits that we consider, as removing one or the other renders the problem of computing the SHAP-score intractable (namely, \#P-hard).},
	language = {en},
	number = {8},
	urldate = {2026-02-21},
	journal = {Proceedings of the AAAI Conference on Artificial Intelligence},
	author = {Arenas, Marcelo and Barceló, Pablo and Bertossi, Leopoldo and Monet, Mikaël},
	month = may,
	year = {2021},
	note = {This article presents an efficient algorithm to compute **SHAP-scores** within specific classification models. The SHAP-score is a prominent explanation method for classifiers that assigns a numerical value to each input feature based on its contribution to the decision process. In general, computing SHAP-scores is computationally intractable due to the model's complexity, often being **\#P-hard**. However, this paper focuses on **Boolean Classifiers**, which return either 1 (accept) or 0 (reject) for a given input. These models are represented as **deterministic** and **decomposable** Boolean circuits, a class that encompasses models like Bayesian Classifiers, Random Forests, and Decision Trees. In this framework, the authors provide a polynomial-time algorithm to compute SHAP-scores over tractable Boolean circuits, initially assuming a uniform distribution over inputs. Both the **determinism** and **decomposability** properties are strictly necessary for this tractability:
- **Determinism** ensures that for every OR gate, no two inputs can be true at the same time for any given assignment.
    
- **Decomposability** requires that for every AND gate, the sets of features in its sub-circuits are pairwise disjoint (they share no variables). The core contribution of the paper is the reduction of the SHAP-score computation to a **\#SAT** problem (model counting). The authors then define a polynomial-time algorithm to solve this specific \#SAT problem using a **bottom-up induction** process},
	keywords = {Axel, Noé},
	pages = {6670--6678},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\KJVMTE4K\\Arenas et al. - 2021 - The Tractability of SHAP-Score-Based Explanations for Classification over Deterministic and Decompos.pdf:application/pdf},
}

@inproceedings{apicella_shap-based_2023,
	title = {{SHAP}-based {Explanations} to {Improve} {Classification} {Systems}},
	url = {https://www.semanticscholar.org/paper/SHAP-based-Explanations-to-Improve-Classification-Apicella-Giugliano/ad8648d55eea6936ff7e47715d6c85cb61154aec},
	abstract = {Explainable Artificial Intelligence (XAI) is a field usually dedicated to offering insights into the decision-making mechanisms of AI models. Its purpose is to enable users to comprehend the reasoning behind the results provided by these models, going beyond mere outputs. In addition, one of the main goals of XAI is to improve the performance of AI models by exploiting the explanations of their decision-making processes. However, a predominant portion of XAI research concentrates on elucidating the functioning of AI systems, with comparatively fewer studies delving into how XAI techniques can be leveraged to enhance the performance of an AI system. This underlines a potential area for further exploration and development in the field of XAI. In this paper we focus on the possibility to enhance the performance of an already trained AI model. To this aim we propose a new scheme of interaction between explanations provided by SHAP XAI method and computations of the responses of a given AI model. This new proposal was tested using the well-known CIFAR-10 dataset and EfficientNet-B2 model, showing promising results.},
	urldate = {2026-02-21},
	author = {Apicella, Andrea and Giugliano, Salvatore and Isgrò, Francesco and Prevete, R.},
	year = {2023},
	note = {This paper describes experiments on using information contained in SHAP explanations to improve a classifier’s performance. This is useful for our research because it gives a new use of generated explanations. The model used in this paper is a pre-trained neural network, fine-tuned on the CIFAR-10 dataset to classify images into 10 exclusive classes. It is composed of a feature-extracting layer and a classification layer. To integrate the explanation to the processing, the authors first encode the explanations through a fully-connected neural-network to extract the most useful information in the explanation, and then they concatenate it with the features extracted my the image model, and feed it to the classification layer. SHAP gives explanations of an input for every class, so there are multiple choices of explanations to integrate in the classification process : the explanation of the real class (which need to be known), the explanation of the predicted class, or an average of all classes explanations, weighted by the predicted score. This study shows that they succeeded to slightly improve the precision of the model (by 1.5\%) using the method with the explanation of the real class, while the two other options are less effective. The integration of the averaged explanations might also slightly improve the precision of the model (the study shows an improvement of 0.06\%).
I think that the described framework is not really suitable for real use case, because the only convincing results are when using the explanations of the real class of the input, which is not known during the inference phase and might also create a bias : if we add features related to the real class then it’s normal for the model to perform better… Also, we can see that when using the explanations of the predicted class as additive input information, the model still predict the same class (that may be wrong) but with a better score, which is why it doesn’t improve the model.
Finally, the paper is overall disappointing. It describes a ton of use cases and related works in the sector of improving model efficiency by using explanations, but only shows experiments on one type of model on one dataset. Also, most of the paper repeats itself, the real content is on the last two pages while all the previous pages act as a long preface.},
	keywords = {Noé},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\WPHILHNY\\Apicella et al. - 2023 - SHAP-based Explanations to Improve Classification Systems.pdf:application/pdf},
}

@misc{zhao_shap_2021,
	title = {{SHAP} values for {Explaining} {CNN}-based {Text} {Classification} {Models}},
	url = {http://arxiv.org/abs/2008.11825},
	doi = {10.48550/arXiv.2008.11825},
	abstract = {Deep neural networks are increasingly used in natural language processing (NLP) models. However, the need to interpret and explain the results from complex algorithms are limiting their widespread adoption in regulated industries such as banking. There has been recent work on interpretability of machine learning algorithms with structured data. But there are only limited techniques for NLP applications where the problem is more challenging due to the size of the vocabulary, high-dimensional nature, and the need to consider textual coherence and language structure. This paper develops a methodology to compute SHAP values for local explainability of CNN-based text classification models. The approach is also extended to compute global scores to assess the importance of features. The results are illustrated on sentiment analysis of Amazon Electronic Review data.},
	urldate = {2026-02-21},
	publisher = {arXiv},
	author = {Zhao, Wei and Joshi, Tarun and Nair, Vijayan N. and Sudjianto, Agus},
	month = jul,
	year = {2021},
	note = {This paper describes a method to explain CNN-based text classification models decisions using Shapley values. Fist of all, the authors pinpoint the struggles when trying to apply already existing SHAP methods to convolutional neural networks. These methods work on structured data an cannot directly be generalized to unstructured data. Moreover, the high dimensionality of the features space is also an issue, as we saw in previous works that the exponential complexity of the computation of the Shapley values is intractable when using hundreds of features. Finally, in NLP models, word are translated in embedding vectors, and the resulting explanation will be in terms of these embedding dimensions which are not interpretable, and makes the diagnostic confusing. Then, the paper proposes CNN SHAP to overcome these difficulties, separated in three steps. First, we let the CNN layers extract semantic features from n-grams of the input text. Because each resulting feature is extracted on the whole group of n consecutive word embeddings, there’s no separation in the embedding dimensions and we can still retrieve which feature is associated to which words. Note that at this point, we don’t know the exact semantic meaning of each extracted feature, only the words that is has been extracted to. Second, we can now apply a SHAP-based method on the extracted features (here, KernelSHAP to get good-time approximations). Third and final, we apply de-duplication over the features : remove the ones that are too similar (keeping only one) an merging the ones that share overlapping n-grams (and adding up their SHAP scores). The experiments are done on the Amazon Elec Review dataset, in a task of classifying positive and negative reviews. The paper show the efficiency of CNN SHAP, that gives SHAP scores directly corresponding of groups of consecutive words. It also shows the results of the de-duplication phase.
This paper is interesting because it shows that SHAP can also be applied to unstructured data when using CNN models. The presentation of the method is clear and concise, there’s no big mathematical background as it is based on already existing methods.},
	keywords = {Noé},
	file = {Preprint PDF:C\:\\Users\\Admin\\Zotero\\storage\\MXEA7SGN\\Zhao et al. - 2021 - SHAP values for Explaining CNN-based Text Classification Models.pdf:application/pdf},
}

@inproceedings{ferrario_how_2022,
	address = {New York, NY, USA},
	series = {{FAccT} '22},
	title = {How {Explainability} {Contributes} to {Trust} in {AI}},
	isbn = {978-1-4503-9352-2},
	url = {https://dl.acm.org/doi/10.1145/3531146.3533202},
	doi = {10.1145/3531146.3533202},
	abstract = {We provide a philosophical explanation of the relation between artificial intelligence (AI) explainability and trust in AI, providing a case for expressions, such as “explainability fosters trust in AI,” that commonly appear in the literature. This explanation relates the justification of the trustworthiness of an AI with the need to monitor it during its use. We discuss the latter by referencing an account of trust, called “trust as anti-monitoring,” that different authors contributed developing. We focus our analysis on the case of medical AI systems, noting that our proposal is compatible with internalist and externalist justifications of trustworthiness of medical AI and recent accounts of warranted contractual trust. We propose that “explainability fosters trust in AI” if and only if it fosters justified and warranted paradigmatic trust in AI, i.e., trust in the presence of the justified belief that the AI is trustworthy, which, in turn, causally contributes to rely on the AI in the absence of monitoring. We argue that our proposed approach can intercept the complexity of the interactions between physicians and medical AI systems in clinical practice, as it can distinguish between cases where humans hold different beliefs on the trustworthiness of the medical AI and exercise varying degrees of monitoring on them. Finally, we apply our account to user’s trust in AI, where, we argue, explainability does not contribute to trust. By contrast, when considering public trust in AI as used by a human, we argue, it is possible for explainability to contribute to trust. Our account can explain the apparent paradox that in order to trust AI, we must trust AI users not to trust AI completely. Summing up, we can explain how explainability contributes to justified trust in AI, without leaving a reliabilist framework, but only by redefining the trusted entity as an AI-user dyad.},
	urldate = {2026-02-21},
	booktitle = {Proceedings of the 2022 {ACM} {Conference} on {Fairness}, {Accountability}, and {Transparency}},
	publisher = {Association for Computing Machinery},
	author = {Ferrario, Andrea and Loi, Michele},
	month = jun,
	year = {2022},
	note = {**Main Idea:** This article provide a philosophical reflection about XAI.
A main part of the article is dedicated to defining explanability  of AI. For the authors, it consist on:
- providing understandable information about the inner-working of a black-box model
    
- and give an explanation about the model outcome.
    
In a second part, authors defines trust in AI by the the fact of reducing the monitoring on models. This leads to a paradox, because if the user need to always check the results of an “explanation model”, it reduces the users trust on the model. So a justified trust (JW-trust) can exists only if the explanation reduces really reduces the need of control.
The end of the article is dedicated to an alternative perspective of the using of AI. During all the article, authors uses the example of a physician using an AI model in medicine. By this way, they introduce the fact that AI does not always take decision alone, it often interact with a human, as called a AI-user dyad. Finally, the explanability issue on AI can be separated in two cases:
- when the object of trust is the AI, XAI is reduced to making AI more reliable
    
- when the object of thrust is the AI-user dyad, the user take a part of the decision process and is able to correct the black-box model mistakes.
    
However, explanability is not a necessary and sufficient condition for user trust in a model. A specific test phase is always necessary.},
	keywords = {Axel},
	pages = {1457--1466},
	file = {Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\WEBTS3QD\\Ferrario et Loi - 2022 - How Explainability Contributes to Trust in AI.pdf:application/pdf},
}

@inproceedings{wilking_fooling_2022,
	address = {Grenoble, France, France},
	title = {Fooling {Perturbation}-{Based} {Explainability} {Methods}},
	url = {https://hal.science/hal-03773429},
	urldate = {2026-02-21},
	booktitle = {Workshop on {Trustworthy} {Artificial} {Intelligence} as a part of the {ECML}/{PKDD} 22 program},
	publisher = {IRT SystemX [IRT SystemX]},
	author = {Wilking, Rahel and Jakobs, Matthias and Morik, Katharina},
	month = sep,
	year = {2022},
	note = {Explanations are used to promote trust in ML, but these explanations can be arbitrarily manipulated. This article talks about scaffolding methods to fool these explanations. Scaffolding uses a wrapper, when imputed real world inputs, it will use the biased original model, otherwise it uses a fair model. The real and not real inputs can be recognized because LIME and other explainability methods based on LIME use perturbations, those perturbations make inputs look not real named Out-of-Distribution (OOD). The attacker will try to hide biased features and highlight unbiased features to fool the explainability method. This article extends the examination of scaffolding to 3 other methods and makes an evaluation and cross evaluation of those attacks with a fooling heuristic they made. The fooling heuristic is based on the detection of the hidden biased features and highlighted unbiased features. They found out LIME KernelSHAP, Anchors and LORE EXPLAIN are all vulnerable, with KernelSHAP and especially LIME being the most vulnerable, Anchors is the most resistant against others method’s attacks and LIME the least resistant against others method’s attack.},
	keywords = {Ant},
	file = {HAL PDF Full Text:C\:\\Users\\Admin\\Zotero\\storage\\Y2K9Z8TG\\Wilking et al. - 2022 - Fooling Perturbation-Based Explainability Methods.pdf:application/pdf},
}

@article{campbell_exact_2022,
	title = {Exact {Shapley} values for local and model-true explanations of decision tree ensembles},
	volume = {9},
	issn = {2666-8270},
	url = {https://www.sciencedirect.com/science/article/pii/S2666827022000500},
	doi = {10.1016/j.mlwa.2022.100345},
	abstract = {Additive feature explanations using Shapley values have become popular for providing transparency into the relative importance of each feature to an individual prediction of a machine learning model. While Shapley values provide a unique additive feature attribution in cooperative game theory, the Shapley values that can be generated for even a single machine learning model are far from unique, with theoretical and implementational decisions affecting the resulting attributions. Here, we consider the application of Shapley values for explaining decision tree ensembles and present a novel approach to Shapley value-based feature attribution that can be applied to random forests and boosted decision trees. This new method provides attributions that accurately reflect details of the model prediction algorithm for individual instances, while being computationally competitive with one of the most widely used current methods. We explain the theoretical differences between the standard and novel approaches and compare their performance using synthetic and real data.},
	urldate = {2026-02-21},
	journal = {Machine Learning with Applications},
	author = {Campbell, Thomas W. and Roder, Heinrich and Georgantas III, Robert W. and Roder, Joanna},
	month = sep,
	year = {2022},
	note = {This papers describes a new method using Shapley values to explain contributions of single features in the decisions of tree-based classifiers (decision trees and ensembles of DTs). Throughout the paper, the described method called Eject is constantly compared to the prior framework TreeSHAP. Eject is intended to fix issues from both following formalisms : the observational approach that wrongly gives non-zero attributions to features which are not used for the decision, and the interventional approach that may consider sets of features that may never be observed in real instances (off-manifold averaging). It is also intended to give model-related explanations, rather than data-related ones. To achieve this, Eject computes the Shapley utility of a coalition by following the decision branch, and when it encounters a feature that is not present in the coalition, it returns the predicted value of the previous node it was in. This method sets a property of “local dummy player” that ensures that non-used features in the prediction receives an attribution of zero in the explanation. Moreover, the complexity of the search-space is reduced, as the features off the decision path are null players.
Multiple experiments are presented, carried out on synthetic and real-life datasets (breast cancer genomic, NHANESI mortality) and show the relevance of the local dummy player property, where TreeSHAP wrongly assigns non-zero attributions that can have high magnitudes. Also, Shapley values of TreeSHAP methods have a much higher variance than Eject’s ones. Finally, this paper shows how different SHAP-based methods can give significantly different explanations, and pinpoint the importance of reflection on the choice of the method used.
What is appreciable about this paper is that every method and every experiment is thoroughly described, with all the formulas, algorithms, codes in appendix for readers to explore and reproduce.},
	keywords = {Noé},
	pages = {100345},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\Admin\\Zotero\\storage\\YIC58EVS\\Campbell et al. - 2022 - Exact Shapley values for local and model-true explanations of decision tree ensembles.pdf:application/pdf},
}

@article{strumbelj_efficient_2010,
	title = {An {Efficient} {Explanation} of {Individual} {Classifications} using {Game} {Theory}},
	volume = {11},
	issn = {1532-4435},
	url = {https://dl.acm.org/doi/10.5555/1756006.1756007},
	abstract = {We present a general method for explaining individual predictions of classification models. The method is based on fundamental concepts from coalitional game theory and predictions are explained with contributions of individual feature values. We overcome the method's initial exponential time complexity with a sampling-based approximation. In the experimental part of the paper we use the developed method on models generated by several well-known machine learning algorithms on both synthetic and real-world data sets. The results demonstrate that the method is efficient and that the explanations are intuitive and useful.},
	urldate = {2026-02-21},
	journal = {J. Mach. Learn. Res.},
	author = {Strumbelj, Erik and Kononenko, Igor},
	month = mar,
	year = {2010},
	note = {This paper describes a method to explain the contribution of individual features in the decisions of any classifier. While model-specific methods exists, having a general method for explaining any classifier’s decision is useful, especially for maintainability reasons and to reduce the dependence between the user and the model. Based on some game theory concepts clearly introduced in the preliminaries of the paper, the contribution function of the model features corresponds to the Shapley value of the coalitional game described by the model, delivering us useful axioms (for instance, the contributions of all the features sum up to the difference between the model’s actual and expected outputs). With this method, the contribution of a feature is computed from the predicted values of perturbations of the input over this feature. However, this method requires exploring the exponentially growing space of all subspaces of features, so computing the exact contributions on a model with a lot of features is not computationally possible. Thus, this paper describes an approximate formula for the Shapley values, and an algorithm to estimate of the contributions by drawing samples from the features space, giving the required number of samples to draw to respect a desired error restriction.
The results part is very complete and shows the strength of this explanation method. We can only salute the comprehensiveness of the study. The described method is tested on several models (decision trees, random forests, SVM, neural networks, …) and several datasets, including synthetic ones but also real applications (like breast cancer recurrence), on a wide range of number of features. The study shows convergence of the error in the estimation of the features contribution, and the different running times for explanations, pointing that the method is not suitable when using a very large number of features (multiple hundreds). Finally, the paper presents visualizations of the features contributions for specific decisions on multiple datasets using different models, composed of the magnitude and sign of the contribution of each feature, showing how positively or negatively each feature affect the final decision. It demonstrate how the explanations can describe what the model did learn, possibly highlighting bad learning processes (over/underfitting, biases), and how we can compare different models using these explanations.},
	keywords = {Noé},
	pages = {1--18},
}

@inproceedings{ribeiro_why_2016,
	address = {San Francisco California USA},
	title = {"{Why} {Should} {I} {Trust} {You}?": {Explaining} the {Predictions} of {Any} {Classifier}},
	isbn = {978-1-4503-4232-2},
	shorttitle = {"{Why} {Should} {I} {Trust} {You}?},
	url = {https://dl.acm.org/doi/10.1145/2939672.2939778},
	doi = {10.1145/2939672.2939778},
	language = {en},
	urldate = {2026-02-05},
	booktitle = {Proceedings of the 22nd {ACM} {SIGKDD} {International} {Conference} on {Knowledge} {Discovery} and {Data} {Mining}},
	publisher = {ACM},
	author = {Ribeiro, Marco Tulio and Singh, Sameer and Guestrin, Carlos},
	month = aug,
	year = {2016},
	note = {This article proposes a {\textbackslash}*{\textbackslash}*Local Interpretable Model Agnostic Explanations (LIME){\textbackslash}*{\textbackslash}* system for classification models. Its objective is to provide a local approximation of a black-box model behavior by an interpretable model (ex: random forest, linear model, etc...). The article also presents an amelioration of this method to provide a more global explanation of the model prediction by selecting local and non-redundant LIME explanations which faithfully represent the black-box model result called {\textbackslash}*{\textbackslash}*Sub-modular picks LIME (SP-LIME){\textbackslash}*{\textbackslash}*.
LIME can be interpreted as a perturbation model. Indeed, from an original interpretable representation \$x'\$, it generates a set of samples \$z'\$ which are drawn by selecting uniformly some \$x'\$ non-zero components. This sampling is weighted by \$ {\textbackslash}pi\_x\$ which defines a locality around \$x'\$ denoted \${\textbackslash}mathcal\{Z\}\$. Then, the problem is to learn an explanation model \$g\$ such that \$g(z') = w\_g {\textbackslash}cdot z'\$ with \$w\_g\$ the importance of an interpretable feature of \$x\$.
The paper also introduce a trade-of between the black-box model (\$f : {\textbackslash}mathbb\{R\}{\textasciicircum}d {\textbackslash}longrightarrow {\textbackslash}mathbb\{R\}\$) interpretation given by \$g\$ and the complexity of this explanation denoted \${\textbackslash}Omega(g)\$. Indeed, to explain a black-box model, we can simply return the model weights, but there are incomprehensible by a human. The LIME problem is then the minimization problem of how unfaithful \$g\$ is in approximating \$f\$ in locality around \$x\$ and having \${\textbackslash}Omega(g)\$ low enough to be human understandable.
In practice, this optimization problem is intractable because \${\textbackslash}Omega(g)\$ specific choice function, that's why a K-LASSO resolution is used. The idea is to select the most \$K\$ relevant features by LASSO algorithm and then get the final weight \$w\_g\$ only for those features.},
	keywords = {Axel},
	pages = {1135--1144},
	file = {Available Version (via Google Scholar):C\:\\Users\\Admin\\Zotero\\storage\\UGTPRETX\\Ribeiro et al. - 2016 - Why Should I Trust You Explaining the Predictions of Any Classifier.pdf:application/pdf},
}

@article{baehrens_how_nodate,
	title = {How to {Explain} {Individual} {Classiﬁcation} {Decisions}},
	abstract = {After building a classiﬁer with modern tools of machine learning we typically have a black box at hand that is able to predict well for unseen data. Thus, we get an answer to the question what is the most likely label of a given unseen data point. However, most methods will provide no answer why the model predicted a particular label for a single instance and what features were most inﬂuential for that particular instance. The only method that is currently able to provide such explanations are decision trees. This paper proposes a procedure which (based on a set of assumptions) allows to explain the decisions of any classiﬁcation method.},
	language = {en},
	author = {Baehrens, David and Schroeter, Timon and Harmeling, Stefan and Harmeling, Stefan and Kawanabe, Motoaki and Kawanabe, Motoaki and Hansen, Katja},
	note = {This paper addresses a key question in machine learning: why does a classifier assign a specific class to a given instance? The authors point out that many high-performing models, especially non-linear ones, behave like black boxes: they produce accurate predictions but do not provide clear explanations of which features influenced a particular decision. While traditional methods often focus on global feature importance, the authors argue that in many applications, it is more useful to obtain local explanations, that is, explanations specific to a single observation.
To tackle this issue, the authors introduce the concept of local explanation vectors. The main idea is to define the explanation of a prediction as the local gradient of the class probability around a given point. In simple terms, this vector indicates how the input features should be modified to change the model’s prediction, and which features are the most influential in that local region. In the binary case, this corresponds to the gradient of the probability of the positive class, allowing one to identify which features increase or decrease the predicted probability.
The paper distinguishes between two main cases. When the model directly provides class probabilities, such as in Gaussian Process Classification (GPC), the gradients can be computed analytically. However, for classifiers that do not naturally output probabilities, such as Support Vector Machines (SVMs), the authors propose approximating the classifier with a probabilistic model, for example using Parzen window estimators, in order to estimate local explanation vectors. This makes the approach applicable to a wide range of models.
The authors validate their method on several datasets. On the Iris dataset, they show that the explanation vectors highlight the importance of features such as petal length and width in distinguishing between classes. Importantly, the explanations vary depending on the specific comparison (e.g., versicolor vs setosa or virginica), illustrating the local nature of the method.
They also apply the approach to handwritten digit classification (USPS dataset), particularly distinguishing between digits like 2 and 8. The explanation vectors indicate which parts of the image should be modified to change the predicted class. Finally, the method is tested in a toxicology application, where it identifies molecular substructures that influence predictions of mutagenicity, with results consistent with domain knowledge.
The main contribution of this paper is to propose a general, local, and interpretable framework for explaining individual classification decisions, even for complex non-linear models. The use of local gradients provides actionable insights, as it not only identifies important features but also indicates how changes in features would affect the prediction. However, the method has some limitations: it depends on the quality of the underlying model, may be less informative when gradients are close to zero, and the approximation step can be challenging in high-dimensional settings.
Overall, this paper is an important contribution to Explainable AI, as it introduces one of the early approaches specifically focused on explaining individual predictions in machine learning models.},
	keywords = {Matthias},
	file = {PDF:C\:\\Users\\Admin\\Zotero\\storage\\5CG9THR2\\Baehrens et al. - How to Explain Individual Classiﬁcation Decisions.pdf:application/pdf},
}

@inproceedings{elshawi_ilime_2019,
	address = {Cham},
	title = {{ILIME}: {Local} and {Global} {Interpretable} {Model}-{Agnostic} {Explainer} of {Black}-{Box} {Decision}},
	isbn = {978-3-030-28730-6},
	shorttitle = {{ILIME}},
	doi = {10.1007/978-3-030-28730-6_4},
	abstract = {Despite outperforming humans in different supervised learning tasks, complex machine learning models are criticised for their opacity which make them hard to trust especially when used in critical domains (e.g., healthcare, self-driving car). Understanding the reasons behind the decision of a machine learning model provides insights into the model and transforms the model from a non-interpretable model (black-box) to an interpretable one that can be understood by humans. In addition, such insights are important for identifying any bias or unfairness in the decision made by the model and ensure that the model works as expected. In this paper, we present ILIME, a novel technique that explains the prediction of any supervised learning-based prediction model by relying on an interpretation mechanism that is based on the most influencing instances for the prediction of the instance to be explained. We demonstrate the effectiveness of our approach by explaining different models on different datasets. Our experiments show that ILIME outperforms a state-of-the-art baseline technique, LIME, in terms of the quality of the explanation and the accuracy in mimicking the behaviour of the black-box model. In addition, we present a global attribution technique that aggregates the local explanations generated from ILIME into few global explanations that can mimic the behaviour of the black-box model globally in a simple way.},
	language = {en},
	booktitle = {Advances in {Databases} and {Information} {Systems}},
	publisher = {Springer International Publishing},
	author = {ElShawi, Radwa and Sherif, Youssef and Al-Mallah, Mouaz and Sakr, Sherif},
	editor = {Welzer, Tatjana and Eder, Johann and Podgorelec, Vili and Kamišalić Latifić, Aida},
	year = {2019},
	note = {This article showcase an ameliorated version of LIME explainer for classification black-box models. At first, LIME is a model agnostic explainer (it means that it can explain a model independently of its architecture) which outputs the local importance of a feature by an weight learned on perturbed features. This weight is then defined as the distance between the original feature representation and the perturbed one. Here, ILIME outperform this model by using the influence to explain the importance of a feature on a prediction. Formally, it is defined as scalar product between original weight of the prediction on the perturbed feature and the loss function gradient evaluated at this point. Finally, the final "importance" value of a feature on the model's prediction is defined as the product of its influence and its original LIME weight. Thus, a synthetic instance will have an important weight if its representation is near to the original feature one, and if it is able to modify the model prediction.
To provide a global explanation of the model behavior, ILIME uses a set of local explanations and defines a dendogramm with hierarchical clustering on explanations (weights). If differs from LIME where the user needed to define the number of global explanation we wanted.},
	keywords = {Axel},
	pages = {53--68},
}
